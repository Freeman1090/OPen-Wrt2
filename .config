# This is an empty file, please overwrite it after generating the# Базовый таргет
CONFIG_TARGET_bcm27xx=y
CONFIG_TARGET_bcm27xx_bcm2711=y
CONFIG_TARGET_bcm27xx_bcm2711_DEVICE_rpi-4=y
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_ROOTFS_PARTSIZE=1024 # Увеличь размер rootfs до 1ГБ, чтобы влезли скрипты и логи

# LuCI и базовое
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-proto-qmi=y

# QModem плагин
CONFIG_PACKAGE_luci-app-qmodem=y

# Драйверы модемов (ОБЯЗАТЕЛЬНО)
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-usb-serial-qualcomm=y
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb3=y # Важно для RPi 4 (синие порты)
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_uqmi=y # Утилита для управления QMI

# I2C и SPI (Для компаса QMC5883L и будущего дисплея ST7735)
CONFIG_PACKAGE_kmod-i2c-bcm2835=y
CONFIG_PACKAGE_kmod-i2c-core=y
CONFIG_PACKAGE_i2c-tools=y
CONFIG_PACKAGE_kmod-spi-bcm2835=y
CONFIG_PACKAGE_kmod-spi-bitbang=y

# Инструменты для скриптов
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_jq=y # Очень пригодится для парсинга JSON от OpenCellID и QMI
CONFIG_PACKAGE_coreutils-stat=y .config file with the source code
